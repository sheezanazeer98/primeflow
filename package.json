{
  "name": "primeflow-plumbing",
  "version": "1.0.0",
  "description": "Premium plumbing website for PrimeFlow Plumbing — serving Northeastern Pennsylvania",
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/input.css -o ./css/styles.css --minify",
    "build:blog": "node scripts/build-blog.js",
    "build": "npm run build:css && npm run build:blog",
    "dev:css": "npx tailwindcss -i ./css/input.css -o ./css/styles.css --watch",
    "serve": "node scripts/dev-server.js",
    "cms": "npx decap-server",
    "dev": "npm run build && node scripts/dev-start.js"
  },
  "devDependencies": {
    "decap-server": "^3.6.0",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
